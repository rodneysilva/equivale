# Auto detect text files and perform LF normalization
* text=auto

# Source code - always LF
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.sh text eol=lf
*.config text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.editorconfig text eol=lf
*.dockerignore text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.dll binary
*.exe binary
*.pdb binary
*.nupkg binary
*.snupkg binary
