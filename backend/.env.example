# =============================================================================
# Equivale API - Variaveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e ajuste os valores conforme seu ambiente.
#
# Uso local (dotnet run):
#   $ cp .env.example .env
#   $ export $(grep -v '^#' .env | xargs)
#
# Uso com docker-compose:
#   $ cp .env.example .env
#   $ docker-compose --env-file .env up -d
# =============================================================================

# --- Ambiente ---
ASPNETCORE_ENVIRONMENT=Development

# --- MongoDB ---
# Connection string do MongoDB (docker usa "mongodb" como host)
MongoDb__ConnectionString=mongodb://localhost:27017
MongoDb__DatabaseName=equivale

# --- JWT Authentication ---
# IMPORTANTE: Em producao, use uma chave secreta com pelo menos 32 caracteres!
# Gerar com: openssl rand -base64 32
JWT_SECRET=dev-secret-change-me-in-production-minimum-32-chars!!
Jwt__Issuer=equivale-api
Jwt__Audience=equivale-client
Jwt__ExpirationMinutes=60

# --- CORS ---
# Origens permitidas para o frontend (separar por virgula no JSON)
AllowedOrigins__0=http://localhost:3000

# --- File Storage (Upload de imagens) ---
FileStorage__BasePath=uploads
FileStorage__UrlPrefix=/api/files
FileStorage__MaxFileSizeBytes=5242880
# Extensões permitidas separadas por virgula
FileStorage__AllowedExtensions__0=.jpg
FileStorage__AllowedExtensions__1=.jpeg
FileStorage__AllowedExtensions__2=.png
FileStorage__AllowedExtensions__3=.gif
FileStorage__AllowedExtensions__4=.webp
