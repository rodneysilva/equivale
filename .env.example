# =============================================================================
# Equivale — Variaveis de Ambiente (docker-compose raiz)
# =============================================================================
# Copie para .env e ajuste:  cp .env.example .env
# docker-compose up --build
# =============================================================================

# --- Backend / .NET ---
# Secret JWT (MINIMO 32 chars em producao). Gerar com: openssl rand -base64 32
JWT_SECRET=dev-secret-change-me-in-production-minimum-32-chars!!

# --- Backend portas/ambiente (defaults do compose) ---
# ASPNETCORE_URLS=http://0.0.0.0:5053
# ASPNETCORE_ENVIRONMENT=Development

# --- MongoDB ---
# Host interno do docker = "mongodb"
# MongoDb__ConnectionString=mongodb://mongodb:27017
# MongoDb__DatabaseName=equivale

# --- Frontend (Vite) ---
# URL publica do backend acessada pelo browser
VITE_API_URL=http://localhost:5053
